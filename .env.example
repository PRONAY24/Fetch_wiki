# --- API gate (required) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WIKI_API_KEY=

# Optional: lock CORS to a single origin (e.g. https://wiki.example.com).
# Leave empty to disable cross-origin requests entirely (same-origin only).
ALLOWED_ORIGIN=

# --- LLM provider ---
LLM_PROVIDER=groq
GROQ_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Server ---
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
